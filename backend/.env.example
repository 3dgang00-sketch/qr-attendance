# ==================== Server Configuration ====================
NODE_ENV=development
PORT=5000
LOG_LEVEL=info

# ==================== Database Configuration ====================
# PostgreSQL connection details
DB_HOST=localhost
DB_PORT=5432
DB_NAME=attendance_db
DB_USER=postgres
DB_PASSWORD=your_password

# ==================== JWT Configuration ====================
# Use a strong secret key (at least 32 characters) for production
JWT_SECRET=your_jwt_secret_key_change_this
JWT_EXPIRY=24h

# ==================== CORS Configuration ====================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ==================== QR Code Configuration ====================
QR_CODE_EXPIRY_MINUTES=5
QR_REFRESH_INTERVAL_SECONDS=30

# ==================== Geofencing Configuration ====================
CAMPUS_LATITUDE=40.2065
CAMPUS_LONGITUDE=-111.8910
GEOFENCE_RADIUS_METERS=200
ALLOW_MULTIPLE_CAMPUSES=true

# ==================== Rate Limiting Configuration ====================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==================== Security Configuration ====================
DEVICE_FINGERPRINT_ENABLED=true
HTTPS_ENFORCED=true

# ==================== Session Configuration ====================
SESSION_TIMEOUT=24

# ==================== Email Configuration ====================
# Gmail: Use Gmail App Password (not regular password)
# Outlook/O365: Use your email and password
# Custom SMTP: Configure host, port, user, password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_FROM=noreply@attendance-system.edu

# ==================== Report Configuration ====================
ENABLE_PDF_REPORTS=true
ENABLE_CSV_REPORTS=true
MAX_RECORDS_PER_REPORT=10000

